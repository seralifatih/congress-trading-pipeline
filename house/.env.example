# Server
PORT=3001
NODE_ENV=development

# Database
DB_PATH=./data/pipeline.db

# Logging
LOG_LEVEL=info

# Pipeline
CRON_SCHEDULE=0 */6 * * *
FETCH_DAYS_BACK=90
LAST_RUN_PATH=./data/last_run.json

# Auth
CRON_SECRET=

# CORS (only needed when running standalone, separate from frontend)
FRONTEND_ORIGIN=http://localhost:3000
